# --- Скомпилированные объектные файлы ---
*.o
*.obj

# --- Исполняемые файлы и прошивки ---
*.elf
*.bin
*.hex
*.srec
*.out
*.img
*.map
*.dump
*.mif

# --- Библиотеки (если вдруг собираются) ---
*.a
*.so
*.la

# --- Каталоги сборки (часто называются build/) ---
build/
out/
Release/
Debug/

# --- Файлы линкера, сгенерированные автоматически (оставь только свои .ld) ---
*.ld.auto

# --- Логи QEMU и GDB ---
*.log
qemu.log
gdb.txt

# --- Резервные копии и временные файлы редакторов ---
*~
*.swp
*.bak
.*.swp
*.d

# --- Файлы Code::Blocks, Eclipse, .vscode которые не относятся к проекту ---
# (если не используешь их как систему сборки — лучше занести в исключения)
.vscode/
.idea/
*.sublime-*

# --- Сгенерированные или загружаемые SDK (если ссылаешься по абсолютному пути) ---
lib/
third_party/

# --- Файлы дампов памяти ---
core
core.*

# --- Инструментарий, который случайно попал в каталог ---
!*.c
!*.h
!*.S
!*.s
!*.ld            # свои скрипты линкера будут отслеживаться
!*.md
!Makefile
!*.cmake
